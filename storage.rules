rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users for now - can be tightened later
    match /media/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Games folder - host HTML game files
    match /games/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Apps folder - host HTML app files
    match /apps/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Tools folder - host HTML tool files
    match /tools/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /user_uploads/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == 'OWNER_UID_HERE');
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
